<Window x:Class="SlydoAddIn.TaskPane.SlidePreviewWpf"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="WidthAndHeight" ShowInTaskbar="False" Topmost="True"
        Width="270" MaxWidth="270"
        ResizeMode="NoResize">
    <Border CornerRadius="12" Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
            Padding="0" Margin="0,0,0,0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="152"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- 缩略图 270x152 16:9 -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0" ClipToBounds="True" Background="#F5F5F5">
                <Image x:Name="PreviewThumb" Stretch="UniformToFill" Width="270" Height="152"
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
            <!-- 信息 -->
            <StackPanel Grid.Row="1" Margin="14,12,14,14">
                <TextBlock x:Name="TitleText" FontWeight="Bold" FontSize="14" Foreground="#333333"
                           TextTrimming="CharacterEllipsis" MaxHeight="20"/>
                <TextBlock x:Name="DescText" FontSize="11" Foreground="#666666" TextWrapping="Wrap"
                           MaxHeight="66" Margin="0,4,0,8" LineHeight="16"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="MatchText" FontWeight="Bold" FontSize="12" Foreground="#009900"/>
                    <Border x:Name="TagBorder" Grid.Column="1" CornerRadius="10"
                            Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="1"
                            Margin="8,0,0,0" Padding="6,1,6,1">
                        <TextBlock x:Name="TagText" FontSize="10" Foreground="#999999"/>
                    </Border>
                    <TextBlock x:Name="SourceText" Grid.Column="2" FontSize="10"
                               Foreground="#AAAAAA" Margin="8,0,0,0" HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
