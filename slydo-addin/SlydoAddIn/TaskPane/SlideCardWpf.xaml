<UserControl x:Class="SlydoAddIn.TaskPane.SlideCardWpf"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="136" HorizontalAlignment="Stretch" Width="Auto" Margin="0,0,0,8">
    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8"
            Padding="0" Cursor="Hand" HorizontalAlignment="Stretch">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.08" Color="#000000"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation To="#F0F4FF" Duration="0:0:0.15"
                                        Storyboard.TargetProperty="Background.Color"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation To="White" Duration="0:0:0.15"
                                        Storyboard.TargetProperty="Background.Color"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid Margin="0" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="130" Height="74" CornerRadius="6"
                        Background="#F5F5F5" BorderBrush="#E8E8E8" BorderThickness="1">
                    <Grid>
                        <Image x:Name="ThumbnailImage" Stretch="UniformToFill" VerticalAlignment="Center"
                               HorizontalAlignment="Center" Visibility="Collapsed"/>
                        <TextBlock x:Name="PlaceholderText" Text="加载中…" Foreground="#CCCCCC"
                                   FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Border x:Name="GoldBadge" Width="20" Height="20"
                                CornerRadius="10" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,4,4,0" Visibility="Collapsed">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FBBF24" Offset="0"/>
                                    <GradientStop Color="#F59E0B" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="⭐" FontSize="11" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Text="标题" FontWeight="Bold" FontSize="13"
                               Foreground="#333333" TextTrimming="CharacterEllipsis" MaxHeight="18"/>
                    <TextBlock x:Name="SummaryText" Text="摘要" FontSize="10.5" Foreground="#888888"
                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                               MaxHeight="30" Margin="0,3,0,4" LineHeight="15"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="MatchText" Text="85% 匹配" FontWeight="Bold" FontSize="11"
                                   Foreground="#009900"/>
                        <TextBlock x:Name="SourceText" Grid.Column="1" Text="联软安全方案"
                                   FontSize="9" Foreground="#AAAAAA" Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Grid>
            <Border Grid.Row="1" Height="28" BorderBrush="#6C63FF" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,7,7" Background="Transparent" Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation To="#6C63FF" Duration="0:0:0.15"
                                                Storyboard.TargetProperty="Background.Color"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation To="Transparent" Duration="0:0:0.15"
                                                Storyboard.TargetProperty="Background.Color"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock x:Name="ImportButton" Text="+ 导入到当前PPT" FontSize="10" FontWeight="Medium"
                           Foreground="#6C63FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
